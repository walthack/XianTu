        "origin": { "name": "太乙传承者", "description": "承接王哲留下的功法与责任，却仍受身份、契券和现实处境牵制。" },
        "spiritRoot": { "name": "生死根·初醒", "tier": "唯一异能", "description": "生死根已能稳定感应死气，并与九阳神功的真阳运行产生联系。", "specialEffects": ["死气感应", "真阳转化", "气轮污染风险"] },
        "talents": [
          { "name": "商机判断", "description": "能够快速估算货物、契约与人情背后的真实价值。" },
          { "name": "临机应变", "description": "在身份受制和资源不足时寻找可执行的破局办法。" }
        ],
        "attributes": { "rootBone": 5, "spirituality": 5, "comprehension": 7, "fortune": 7, "charm": 6, "temperament": 6 },
        "locked": true
