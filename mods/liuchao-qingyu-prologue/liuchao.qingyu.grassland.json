{
  "schema": "xiantu.scenario-mod",
  "version": 1,
  "manifest": {
    "id": "liuchao.qingyu.grassland",
    "name": "六朝清羽记·草原鹰帜",
    "version": "1.0.0",
    "author": "XianTu Scenario Team",
    "description": "以《六朝清羽记》第一集草原战局为蓝本的短篇 Strict 剧本。玩家作为独立角色进入左武军、兽蛮人与西方联军交锋的时间点。"
  },
  "world": {
    "name": "六朝并置世界",
    "era": "大汉左武军北征草原时期",
    "background": "多个历史时代与异族文明并存于同一世界。大汉左武军深入西北草原清剿兽蛮诸部，太乙真宗掌教王哲以师帅身份统军。西方强国的军势正在越过波斯方向逼近，草原上的局部战争即将演变为东西方军团的正面碰撞。",
    "specialRules": [
      "本世界是历史人物、六朝政权、异族与修炼体系并置的架空世界，不按现实历史年份推演",
      "修炼叙事优先采用九境语汇与九阳神功的一阳至九阳阶段，不把人物自动改写为练气、金丹、元婴体系",
      "军队、官署、商旅和宗门是并列组织类型，不把所有势力都改写为修仙宗门",
      "程宗扬是正典异界来客，玩家是同一时间点出现的独立角色，不得把两者合并",
      "允许玩家改变个人命运和局部事件结果，但左武军、兽蛮诸部与西方联军的核心名称不得改写"
    ],
    "continents": [
      {
        "id": "liuchao.region.six_dynasties",
        "name": "六朝诸国",
        "description": "汉、宋、晋等政权与众多宗门、军镇、商路并存的东方世界。"
      },
      {
        "id": "liuchao.region.western_realms",
        "name": "西方诸国",
        "description": "波斯与罗马等强国所在的西方区域，其军势可沿草原商路东进。"
      }
    ]
  },
